{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "installCommand": "cd TuniTransport && npm install",
  "buildCommand": "cd TuniTransport && npx expo export --platform web",
  "outputDirectory": "TuniTransport/dist",
  "rewrites": [{ "source": "/(.*)", "destination": "/index.html" }]
}
